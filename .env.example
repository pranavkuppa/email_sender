#Gmail credentials and configuration for sending emails
SMTP_HOST     = "smtp.gmail.com" # Check your email provider's SMTP settings
SMTP_PORT     = 587
SENDER_EMAIL  = "you@gmail.com"       # Your Email
SENDER_PASS   = "xxxx xxxx xxxx xxxx" # Password
CC_EMAIL= "cc@gmail.com" # Optional CC email address (leave blank for no CC)

#Edit these details accordingly
CSV_FILE      = "students.csv" # Name of your excel sheet
TEMPLATE_FILE = "email_template.txt"
PLACEHOLDER_FILE = "placeholders.json"
LOG_FILE      = f"logs/results_{datetime.now().strftime('%Y%m%d_%H%M%S')}.csv"

#If emails are being sent successfully but not appearing in your Sent folder, set up IMAP details below to save a copy of each sent email. 
#Gmail does this automatically, so leave blank for Gmail.
IMAP_HOST=
IMAP_PORT=
IMAP_SENT_FOLDER=


DELAY_BETWEEN_EMAILS = 1.5  # seconds
BATCH_SIZE    = 50          # pause after every 50 emails
BATCH_PAUSE   = 10          # seconds to pause between batches

##Add subject of the email here(same format as the template file with placeholders if needed)

EMAIL_SUBJECT=